<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UniversalYogaCustomerApp.Views.HomePage"
             Title="Welcome">
    <VerticalStackLayout Padding="30" Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">
        <Image Source="app_logo.png" WidthRequest="180" HeightRequest="120"/>
        <Label Text="Welcome to Universal Yoga" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label Text="Your path to balance and mindfulness starts here." FontSize="16" HorizontalOptions="Center"/>
        <Button Text="Get Started" Clicked="OnGetStartedClicked" />
    </VerticalStackLayout>
</ContentPage>
