<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="UniversalYogaCustomerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:UniversalYogaCustomerApp.Views">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:HomePage}" />

    <ShellContent
        Title="Available Classes"
        ContentTemplate="{DataTemplate local:CoursesPage}"
        Route="CoursesPage" />

    <ShellContent
        Title="Checkout"
        ContentTemplate="{DataTemplate local:CheckoutPage}"
        Route="CheckoutPage" />

    <ShellContent
        Title="Contact"
        ContentTemplate="{DataTemplate local:ContactPage}" />

</Shell>