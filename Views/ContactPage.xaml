<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UniversalYogaCustomerApp.Views.ContactPage"
             Title="Contact Us">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="We'd love to hear from you!" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Entry x:Name="NameEntry" Placeholder="Your Name" />
            <Entry x:Name="EmailEntry" Placeholder="Your Email" Keyboard="Email" />
            <Editor x:Name="MessageEditor" Placeholder="Your Message" HeightRequest="120" />

            <Button Text="Send Message" Clicked="OnSendMessageClicked" />

            <Label x:Name="StatusLabel" 
                   TextColor="Green" 
                   FontAttributes="Italic" 
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
